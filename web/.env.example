# Ancora Health — frontend environment configuration.
# Copy to `.env.local` for local development. Values below are the local defaults.

# --- Backend endpoints (browser-visible, hence NEXT_PUBLIC_*) ---
# Project slug; drives the default realtime host ws.{project}.vforce360.ai.
NEXT_PUBLIC_PROJECT_SLUG=ancora
# REST + GraphQL base URL, routed via the Kong edge. The Go service (cmd/server)
# listens on :8000 by default in local development.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# GraphQL endpoint path appended to the API base URL (gqlgen behind the edge).
NEXT_PUBLIC_GRAPHQL_PATH=/graphql
# WebSocket base URL for realtime features (messaging, notifications, WebRTC
# signaling). Defaults to wss://ws.{project}.vforce360.ai when unset; override
# it to point at a local dev server.
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000
# Service name advertised on outbound OpenTelemetry baggage.
NEXT_PUBLIC_OTEL_SERVICE_NAME=ancora-web

# --- Trusted identity headers (server-side only) ---
# The edge/proxy authenticates the request and injects the resolved identity as
# trusted headers. The app NEVER parses a JWT or performs RBAC itself — it reads
# these headers server-side and gates the UI by the resolved role.
# Header carrying the resolved role: one of patient | provider | scheduler | admin.
ANCORA_ROLE_HEADER=x-ancora-role
# Header carrying the resolved user display name / id.
ANCORA_USER_HEADER=x-ancora-user
